<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  SALTZAILE MENU NAGUSIAREN INTERFAZE GRAFIKOA
  File: SaltzaileMenuPrintzipala.fxml
  Author: AIA
  Version: 2.1
  Since: 2026

  Description: Saltzaile menu nagusiaren interfaze grafikoa. Menu honetatik 
  saltzaileak atal desberdinak atzi ditzake: Erabiltzaile kudeaketa (saltzaileak),
  Bezero kudeaketa (bezeroak, eskaerak), eta Abisuak (bezeroen abisuak, kontrolak, eguneraketak).
  
  CSS Styles: stylesheets @../../estilos/saltzaileMenu.css
  FXML Controller: saltzaileLeihoak.saltzaileMenuPrintzipala.SaltzaileMenuPrintzipalaKontrolagailua
-->

<GridPane fx:controller="saltzaileLeihoak.saltzaileMenuPrintzipala.SaltzaileMenuPrintzipalaKontrolagailua" 
          maxHeight="-Infinity" 
          maxWidth="-Infinity" 
          minHeight="-Infinity" 
          minWidth="-Infinity" 
          prefHeight="400.0" 
          prefWidth="600.0" 
          stylesheets="@../../estilos/saltzaileMenu.css"
          styleClass="saltzaile-grid"
          xmlns="http://javafx.com/javafx/8" 
          xmlns:fx="http://javafx.com/fxml/1">
          
  <columnConstraints>
    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    <ColumnConstraints hgrow="SOMETIMES" maxWidth="194.0" minWidth="10.0" prefWidth="111.0" />
    <ColumnConstraints hgrow="SOMETIMES" maxWidth="236.0" minWidth="10.0" prefWidth="196.0" />
  </columnConstraints>
  
  <rowConstraints>
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
  </rowConstraints>
  
   <children>
      <MenuBar prefHeight="22.0" prefWidth="476.0" GridPane.columnSpan="2" styleClass="saltzaile-menu-bar">
        <menus>
          <!-- Erabiltzaile kudeaketa menua - IDa gehitu diogu kontrolatzeko -->
          <Menu fx:id="erabiltzaileKudeaketaMenu" mnemonicParsing="false" text="Erabiltzaile kudeaketa">
            <items>
              <MenuItem fx:id="saltzaileInformazioaItem" onAction="#irekiSaltzaileTaula" mnemonicParsing="false" text="Saltzaile informazioa" />
              <MenuItem fx:id="saltzaileKudeaketaItem" onAction="#irekiSaltzaileKudeaketa" mnemonicParsing="false" text="Saltzaile gehitu/ezabatu/aldatu" />
            </items>
          </Menu>
          
          <Menu mnemonicParsing="false" text="Bezero kudeaketa">
            <items>
              <MenuItem onAction="#irekiBezeroTaula" mnemonicParsing="false" text="Bezero informazioa" />
              <MenuItem onAction="#irekiBezeroKudeaketa" mnemonicParsing="false" text="Bezero gehitu/ezabatu/aldatu" />
              <MenuItem onAction="#irekiBezeroTaulaEskaerak" mnemonicParsing="false" text="Bezero eskaerak" />
            </items>
          </Menu>
          
          <Menu mnemonicParsing="false" text="Abisuak">
            <items>
              <MenuItem onAction="#irekiAbisuak" mnemonicParsing="false" text="Ikusi bezeroen abisuak" />
              <MenuItem onAction="#irekiTxerteketakEzabaketak" mnemonicParsing="false" text="Kontrolak" />
              <MenuItem onAction="#irekiEguneraketak" mnemonicParsing="false" text="Eguneraketak" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      
      <MenuBar GridPane.columnIndex="2" styleClass="saltzaile-user-menu">
        <menus>
          <Menu fx:id="saltzaileMenu" mnemonicParsing="false" text="Kargatzen...">
            <items>
              <MenuItem onAction="#saioaIxten" mnemonicParsing="false" text="Saioa itxi" styleClass="menu-item-saioaIxten" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </children>
</GridPane>