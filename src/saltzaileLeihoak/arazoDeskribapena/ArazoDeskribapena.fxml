<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<!--
  ============================================================================
  ARAZOAREN DESKRIBAPENAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: ArazoDeskribapena.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
 
  Arazoaren deskribapenaren interfaze grafikoa. Leiho honek abisu jakin baten 
  informazio osoa erakusten du: bezeroa, data, kontzeptua eta deskribapena. 
  Bi botoi ditu: Itzuli eta Amaituta.
  
  CSS Styles:
 
  - stylesheets: @../../estilos/abisuak.css
  - styleClass: abisuak-container, abisuak-info-panel, boton-amaituta, boton-secundario
  
  FXML Controller:
 
  @see saltzaileLeihoak.arazoDeskribapena.ArazoDeskribapenaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="saltzaileLeihoak.arazoDeskribapena.ArazoDeskribapenaKontrolagailua" 
      spacing="15" 
      alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="500.0" 
      prefWidth="700.0"
      stylesheets="@../../estilos/abisuak.css"
      styleClass="abisuak-container">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <children>
        <Label text="Arazoaren Deskribapena" styleClass="titulo-principal">
            <VBox.margin><Insets bottom="10" /></VBox.margin>
        </Label>

        <Separator prefWidth="600.0" />

        <GridPane hgap="15" vgap="10" styleClass="abisuak-info-panel">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            <children>
                <Label text="Bezeroa:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="abisuak-campo-label" />
                <Label fx:id="bezeroIzenaLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="abisuak-campo-valor" />
                <Label text="Data:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="abisuak-campo-label" />
                <Label fx:id="dataLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="abisuak-campo-valor" />
            </children>
            <columnConstraints>
                <ColumnConstraints minWidth="80.0" />
                <ColumnConstraints minWidth="200.0" />
            </columnConstraints>
        </GridPane>

        <Label text="Kontzeptua:" styleClass="abisuak-campo-label" />
        <TextField fx:id="kontzeptuaField" editable="false" styleClass="abisuak-kontzeptua-field" />

        <Label text="Deskribapena:" styleClass="abisuak-campo-label" />
        <TextArea fx:id="deskribapenaArea" editable="false" wrapText="true" prefRowCount="8" styleClass="abisuak-deskribapena-area" />

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <children>
                <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" prefWidth="100.0" />
                <Button onAction="#amaituta" text="Amaituta" styleClass="boton-amaituta" prefWidth="100.0" />
            </children>
            <VBox.margin><Insets top="10" /></VBox.margin>
        </HBox>
    </children>
</VBox>