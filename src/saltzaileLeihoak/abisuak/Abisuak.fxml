<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<!--
  ============================================================================
  ABISUEN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: Abisuak.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
 
  Bezeroen abisuen interfaze grafikoa. Taula honek bezeroen abisu guztiak 
  erakusten ditu: bezeroa, kontzeptua, deskribapena eta data. Abisu baten 
  gainean klik bikoitza eginez gero, arazoaren deskribapen osoa ikusteko leihoa 
  irekitzen da.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/abisuak.css
  - styleClass: abisuak-container, abisuak-tabla, pagination
  
  FXML Controller:
  
  @see saltzaileLeihoak.abisuak.AbisuakKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="saltzaileLeihoak.abisuak.AbisuakKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="800.0"
      spacing="10"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/abisuak.css"
      styleClass="abisuak-container">
      
   <children>
      <Label text="Bezeroen Abisuak" styleClass="titulo-principal">
         <VBox.margin><Insets top="15" /></VBox.margin>
      </Label>
      
      <Separator prefWidth="600.0" />
      
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS" prefHeight="400.0" styleClass="abisuak-tabla">
        <columns>
          <TableColumn fx:id="bezeroIzenaColumn" prefWidth="150.0" text="Bezeroa" />
          <TableColumn fx:id="kontzeptuaColumn" prefWidth="200.0" text="Kontzeptua" />
          <TableColumn fx:id="deskribapenaColumn" prefWidth="300.0" text="Deskribapena" />
          <TableColumn fx:id="dataColumn" prefWidth="120.0" text="Data" />
        </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <Pagination fx:id="pagination" styleClass="pagination" />
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 20 15 0;">
         <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
      </HBox>
   </children>
</VBox>