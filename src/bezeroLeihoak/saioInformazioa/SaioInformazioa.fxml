<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="bezeroLeihoak.saioInformazioa.SaioInformazioaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="500.0" 
      prefWidth="600.0"
      spacing="15"
      alignment="TOP_CENTER"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">
      
   <children>
      <!-- Título -->
      <HBox spacing="15" alignment="CENTER">
         <children>
            <Label text="Saioaren Informazioa">
               <font>
                  <Font name="Cambria" size="28.0" />
               </font>
            </Label>
            <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                <Image url="@../../irudiak/usuario.png" />
            </ImageView>
         </children>
      </HBox>
      
      <!-- Separador -->
      <Separator prefWidth="400.0" />
      
      <!-- Formulario -->
      <GridPane hgap="15" vgap="12" alignment="CENTER">
         <children>
            <!-- Izena -->
            <Label text="Izena *:" GridPane.columnIndex="0" GridPane.rowIndex="0">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <children>
                  <TextField fx:id="ipiniIzena" prefWidth="250.0" promptText="Izena" />
                  <Button fx:id="editatuIzenaButton" text="✏️" prefWidth="40" 
                          onAction="#editatuIzena" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
            <!-- Abizena -->
            <Label text="Abizena:" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <TextField fx:id="ipiniAbizenak" prefWidth="250.0" promptText="Abizenak" />
                  <Button fx:id="editatuAbizenaButton" text="✏️" prefWidth="40"
                          onAction="#editatuAbizena" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
            <!-- NAN -->
            <Label text="NAN *:" GridPane.columnIndex="0" GridPane.rowIndex="2">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <TextField fx:id="ipiniNan" prefWidth="250.0" promptText="NAN" />
                  <Button fx:id="editatuNanButton" text="✏️" prefWidth="40"
                          onAction="#editatuNan" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
            <!-- Telefonoa -->
            <Label text="Telefonoa *:" GridPane.columnIndex="0" GridPane.rowIndex="3">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
               <children>
                  <TextField fx:id="ipiniTelefonoa" prefWidth="250.0" promptText="Telefonoa" />
                  <Button fx:id="editatuTelefonoaButton" text="✏️" prefWidth="40"
                          onAction="#editatuTelefonoa" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
            <!-- Helbidea -->
            <Label text="Helbidea:" GridPane.columnIndex="0" GridPane.rowIndex="4">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <children>
                  <TextField fx:id="ipiniHelbidea" prefWidth="250.0" promptText="Helbidea" />
                  <Button fx:id="editatuHelbideaButton" text="✏️" prefWidth="40"
                          onAction="#editatuHelbidea" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
            <!-- Emaila -->
            <Label text="Emaila *:" GridPane.columnIndex="0" GridPane.rowIndex="5">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
               <children>
                  <TextField fx:id="ipiniEmaila" prefWidth="250.0" promptText="Emaila" />
                  <Button fx:id="editatuEmailaButton" text="✏️" prefWidth="40"
                          onAction="#editatuEmaila" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
             <!-- Erabiltzailea -->
            <Label text="Erabiltzailea *:" GridPane.columnIndex="0" GridPane.rowIndex="6">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
               <children>
                  <TextField fx:id="ipiniErabiltzailea" prefWidth="250.0" promptText="Erabiltzailea" />
                  <Button fx:id="editatuErabiltzaileaButton" text="✏️" prefWidth="40"
                          onAction="#editatuErabiltzailea" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
            
             <!-- Pasahitza -->
            <Label text="Pasahitza *:" GridPane.columnIndex="0" GridPane.rowIndex="7">
               <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="7">
               <children>
                  <TextField fx:id="ipiniPasahitza" prefWidth="250.0" promptText="Pasahitza" />
                  <Button fx:id="editatuPasahitzaButton" text="✏️" prefWidth="40"
                          onAction="#editatuPasahitza" style="-fx-cursor: hand;"/>
               </children>
            </HBox>
         </children>
         
         <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="80" />
            <ColumnConstraints halignment="LEFT" minWidth="300" />
         </columnConstraints>
      </GridPane>
      
      <!-- Separador -->
      <Separator prefWidth="400.0" />
      
      <!-- Botones -->
      <HBox spacing="20" alignment="CENTER">
         <children>
            <Button fx:id="gordeButton" onAction="#gordeInfo" text="Gorde" prefWidth="100">
               <font><Font size="14.0" /></font>
            </Button>
            <Button fx:id="itzuliButton" onAction="#itzuli" text="Itzuli" prefWidth="100">
               <font><Font size="14.0" /></font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>