<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<!--
  ============================================================================
  ERREGISTRATU LEIHOAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: Erregistratu.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
  
  Erregistratu leihoaren interfaze grafikoa. Leiho honek erabiltzaile berria 
  sortzeko eremuak ditu: erabiltzaile izena, pasahitza eta pasahitza errepikatzeko.
  Bi botoi ditu: Erabiltzaile sortu eta Itzuli.
  
  CSS Styles:
 
  - stylesheets: @../../estilos/formularios.css
  - styleClass: erregistratu-container, erregistratu-panel
  
  FXML Controller:
  
  @see orokorLeihoak.erregistratu.ErregistratuKontrolagailua
  
  ============================================================================
-->

<AnchorPane fx:controller="orokorLeihoak.erregistratu.ErregistratuKontrolagailua" 
            xmlns:fx="http://javafx.com/fxml" 
            prefWidth="400" 
            prefHeight="350"
            stylesheets="@../../estilos/formularios.css"
            styleClass="formulario-panel">
   <children>
      <VBox alignment="TOP_CENTER" spacing="15" layoutX="20" layoutY="20" prefWidth="360" prefHeight="310" styleClass="erregistratu-panel">
         <children>
            <Label text="Erregistratu" styleClass="titulo-principal" />
            <VBox spacing="5" prefWidth="360">
               <children>
                  <Label text="Erabiltzaile berria:" styleClass="campo-etiqueta" />
                  <TextField fx:id="erabiltzaileBerria" promptText="Erabiltzailea..." styleClass="campo-texto" />
               </children>
            </VBox>
            <VBox spacing="5" prefWidth="360">
               <children>
                  <Label text="Pasahitza:" styleClass="campo-etiqueta" />
                  <PasswordField fx:id="pasahitzaBerria" promptText="Pasahitza..." styleClass="campo-texto" />
               </children>
            </VBox>
            <VBox spacing="5" prefWidth="360">
               <children>
                  <Label text="Pasahitza errepikatu:" styleClass="campo-etiqueta" />
                  <PasswordField fx:id="errepikatuPasahitzaBerria" promptText="Errepikatu pasahitza..." styleClass="campo-texto" />
               </children>
            </VBox>
            <HBox spacing="20" alignment="CENTER">
               <children>
                  <Button onAction="#sortuErabiltzailea" text="Erabiltzaile sortu" styleClass="boton-exito" prefWidth="150" />
                  <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" prefWidth="150" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>