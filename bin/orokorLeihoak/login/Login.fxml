<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<!--
  Login leihoaren interfaze grafikoa.
  
  Leiho honek erabiltzaileak saioa hasteko bi eremu ditu:
  - Erabiltzailea: erabiltzaile izena sartzeko testu eremua
  - Pasahitza: pasahitza sartzeko pasahitz eremua
  
  Bi botoi ditu:
  - Sartu: erabiltzailea identifikatzeko
  - Erregistratu: erabiltzaile berria sortzeko leihoa irekitzeko
  
  @controller orokorLeihoak.login.LoginKontrolagailua
-->

<AnchorPane fx:controller="orokorLeihoak.login.LoginKontrolagailua" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <!-- Erabiltzailea etiketa -->
      <Label layoutX="267.0" layoutY="22.0" text="Erabiltzailea:" />
      
      <!-- Erabiltzaile izena sartzeko testu eremua -->
      <TextField fx:id="erabiltzaileak" layoutX="226.0" layoutY="39.0" />
      
      <!-- Pasahitza etiketa -->
      <Label layoutX="275.0" layoutY="74.0" text="Pasahitza:" />
      
      <!-- Pasahitza sartzeko pasahitz eremua -->
      <PasswordField fx:id="pasahitza" layoutX="226.0" layoutY="91.0" />
      
      <!-- Sartu botoia: identifikazioa egiten du -->
      <Button layoutX="198.0" layoutY="130.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="77.0" text="Sartu" onAction="#sartu"/>
      
      <!-- Erregistratu botoia: erregistro leihoa irekitzen du -->
      <Button layoutX="337.0" layoutY="130.0" mnemonicParsing="false" text="Erregitsratu" onAction="#erregistratu"/>
   </children>
</AnchorPane>