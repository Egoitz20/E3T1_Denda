<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  LOGIN LEIHOAREN INTERFAZE GRAFIKOA
  File: Login.fxml
  Author: AIA
  Version: 2.1
  Since: 2026

  Description: Login leihoaren interfaze grafikoa. Leiho honek erabiltzaileak 
  saioa hasteko bi eremu ditu: erabiltzaile izena eta pasahitza.
  Bi botoi ditu: Sartu eta Erregistratu.

  CSS Styles: stylesheets @../../estilos/login.css
  FXML Controller: orokorLeihoak.login.LoginKontrolagailua
-->

<AnchorPane fx:controller="orokorLeihoak.login.LoginKontrolagailua" 
            maxHeight="-Infinity" 
            maxWidth="-Infinity" 
            minHeight="-Infinity" 
            minWidth="-Infinity" 
            prefHeight="400.0" 
            prefWidth="600.0" 
            stylesheets="@../../estilos/login.css"
            styleClass="login-container"
            xmlns="http://javafx.com/javafx/8" 
            xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" spacing="20" layoutX="150" layoutY="50" prefWidth="320" styleClass="login-panel">
         <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
         </padding>
         <children>
            <Label text="Login" styleClass="login-titulo" />
            <TextField fx:id="erabiltzaileak" promptText="Erabiltzailea" styleClass="campo-texto, login-campo" />
            <PasswordField fx:id="pasahitza" promptText="Pasahitza" styleClass="campo-texto, login-campo" />
            <HBox spacing="20" alignment="CENTER">
               <Button text="Sartu" onAction="#sartu" styleClass="login-boton" />
               <Button text="Erregistratu" onAction="#erregistratu" styleClass="boton-registro" />
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>