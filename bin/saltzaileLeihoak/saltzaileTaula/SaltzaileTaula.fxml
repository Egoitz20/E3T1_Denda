<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<!--
  Saltzaileen taularen interfaze grafikoa.
  
  Taula honek saltzaile guztien informazioa erakusten du:
  - IDa, izena-abizenak, erabiltzailea, pasahitza, emaila, telefonoa
  
  Bilaketa funtzionalitatea du (izena, erabiltzailea edo IDaren arabera)
  eta orrikatzea (10 erregistro orriko).
  
  @controller saltzaileLeihoak.saltzaileTaula.SaltzaileTaulaKontrolagailua
-->

<VBox fx:controller="saltzaileLeihoak.saltzaileTaula.SaltzaileTaulaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER">
      
   <children>
      <Label text="Saltzaile informazioa">
         <font>
            <Font name="Calibri" size="25.0" />
         </font>
      </Label>
      
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS" prefHeight="400.0">
        <columns>
          <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="izenaAbizenakColumn" prefWidth="170.0" text="Izena-Abizenak" />
          <TableColumn fx:id="erabiltzaileaColumn" prefWidth="120.0" text="Erabiltzailea" />
          <TableColumn fx:id="pasahitzaColumn" prefWidth="100.0" text="Pasahitza" />
          <TableColumn fx:id="emailaColumn" prefWidth="200.0" text="Emaila" />
          <TableColumn fx:id="telefonoaColumn" prefWidth="110.0" text="Telefonoa" />
        </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <children>
            <Pagination fx:id="pagination" />
         </children>
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_LEFT">
         <children>
            <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../irudiak/lupa.png" />
               </image>
            </ImageView>
            <TextField fx:id="bilaketaField" prefWidth="350.0" promptText="Bilatu izena, erabiltzailea edo ID..." />
            <Button onAction="#itzuli" text="Itzuli">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>