<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  SALTZAILEEN TAULAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: SaltzaileTaula.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
 
  Saltzaileen taularen interfaze grafikoa. Taula honek saltzaile guztien 
  informazioa erakusten du: IDa, izena-abizenak, erabiltzailea, pasahitza, 
  emaila, telefonoa. Bilaketa funtzionalitatea du (izena, erabiltzailea edo 
  IDaren arabera) eta orrikatzea.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/taulak.css
  - styleClass: saltzaile-taula, taula-generikoa, pagination
  
  FXML Controller:
 
  @see saltzaileLeihoak.saltzaileTaula.SaltzaileTaulaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="saltzaileLeihoak.saltzaileTaula.SaltzaileTaulaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/taulak.css"
      styleClass="bezero-kudeaketa-container">
      
   <children>
      <Label text="Saltzaile informazioa" styleClass="titulo-principal" />
      
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS" prefHeight="400.0" styleClass="saltzaile-taula, taula-generikoa">
        <columns>
          <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" styleClass="id-column, celda-id" />
          <TableColumn fx:id="izenaAbizenakColumn" prefWidth="170.0" text="Izena-Abizenak" styleClass="izena-column" />
          <TableColumn fx:id="erabiltzaileaColumn" prefWidth="120.0" text="Erabiltzailea" styleClass="erabiltzailea-column" />
          <TableColumn fx:id="pasahitzaColumn" prefWidth="100.0" text="Pasahitza" />
          <TableColumn fx:id="emailaColumn" prefWidth="200.0" text="Emaila" styleClass="emaila-column" />
          <TableColumn fx:id="telefonoaColumn" prefWidth="110.0" text="Telefonoa" styleClass="telefonoa-column" />
        </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <Pagination fx:id="pagination" styleClass="pagination" />
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bezero-bilaketa-bar">
         <children>
            <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true" styleClass="boton-bilaketa">
                <Image url="@../../irudiak/lupa.png" />
            </ImageView>
            <TextField fx:id="bilaketaField" prefWidth="350.0" promptText="Bilatu izena, erabiltzailea edo ID..." styleClass="bezero-bilaketa-field" />
            <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
         </children>
      </HBox>
   </children>
</VBox>