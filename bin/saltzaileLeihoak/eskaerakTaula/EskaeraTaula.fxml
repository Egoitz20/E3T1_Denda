<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  BEZEROAREN ESKAEREN TAULAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: EskaeraTaula.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
  
  Bezeroaren eskaeren taularen interfaze grafikoa. Taula honek bezero jakin baten 
  eskaera guztiak erakusten ditu: produktu izena, kategoria, kopurua, egoera, 
  eskaera data, saltzailea. Bilaketa funtzionalitatea du (produktua, kategoria 
  edo saltzailearen arabera) eta orrikatzea.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/taulak.css
  - styleClass: taula-generikoa, pagination
  
  FXML Controller:
  
  @see saltzaileLeihoak.eskaerakTaula.EskaerakTaulaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="saltzaileLeihoak.eskaerakTaula.EskaerakTaulaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/taulak.css"
      styleClass="bezero-kudeaketa-container">
      
   <children>
      <Label fx:id="bezeroIzenburua" text="Bezeroaren Eskaerak" styleClass="titulo-principal" />
      
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS" prefHeight="400.0" styleClass="taula-generikoa">
        <columns>
          <TableColumn fx:id="produktuIzenaColumn" prefWidth="200.0" text="Produktu Izena" />
          <TableColumn fx:id="produktuKategoriaColumn" prefWidth="150.0" text="Kategoria" />
          <TableColumn fx:id="produktuKopuruaColumn" prefWidth="80.0" text="Kopurua" />
          <TableColumn fx:id="produktuEgoeraColumn" prefWidth="150.0" text="Eskari Egoera" />
          <TableColumn fx:id="produktuEskaeraDataColumn" prefWidth="150.0" text="Eskaera Data" />
          <TableColumn fx:id="saltzaileIzenaColumn" prefWidth="150.0" text="Saltzailea" />
        </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <Pagination fx:id="pagination" styleClass="pagination" />
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bezero-bilaketa-bar">
         <children>
            <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true" styleClass="boton-bilaketa">
                <Image url="@../../irudiak/lupa.png" />
            </ImageView>
            <TextField fx:id="bilaketaField" prefWidth="350.0" promptText="Bilatu produktua, kategoria edo saltzailea..." styleClass="bezero-bilaketa-field" />
            <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
         </children>
      </HBox>
   </children>
</VBox>