<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  TXERTAKETEN ETA EZABAKETEN KONTROLAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: TxertaketakEzabaketakKontrola.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
 
  Txertaketen eta ezabaketen kontrolaren interfaze grafikoa. Taula honek 
  datu-basean egindako txertaketa eta ezabaketa guztiak erakusten ditu, 
  bi zutabetan banatuta: txertaketak eta ezabaketak.
  
  CSS Styles:
 
  - stylesheets: @../../estilos/taulak.css
  - styleClass: taula-bizkarga, taula-generikoa
  
  FXML Controller:
  
  @see saltzaileLeihoak.txertaketakEzabaketakKontrola.TxertaketakEzabaketakKontrolaKontrolagailua
  
  ============================================================================
-->

<VBox alignment="TOP_CENTER" 
      prefHeight="550.0" 
      prefWidth="900.0" 
      spacing="10" 
      stylesheets="@../../estilos/taulak.css"
      styleClass="bezero-kudeaketa-container"
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="saltzaileLeihoak.txertaketakEzabaketakKontrola.TxertaketakEzabaketakKontrolaKontrolagailua">
      
   <children>
      <Label text="Txertaketak Ezabaketak Kontrola" styleClass="titulo-principal" />
      
      <TableView fx:id="tableView" prefHeight="400.0" VBox.vgrow="ALWAYS" styleClass="taula-bizkarga">
        <columns>
          <TableColumn fx:id="txertaketakColumn" prefWidth="500.0" text="TXERTAKETAK" />
          <TableColumn fx:id="ezabaketakColumn" prefWidth="500.0" text="EZABAKETAK" />
        </columns>
      </TableView>
      
      <HBox alignment="CENTER_LEFT" spacing="10">
         <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
      </HBox>
   </children>
</VBox>