<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  OTZARAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: Otzara.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
  
  Otzararen interfaze grafikoa. Bezeroak erositako produktuak ikusteko eta 
  kudeatzeko leihoa. Produktuen zerrenda erakusten du, kantitateak aldatzeko 
  aukerarekin, eta erosketaren laburpena (totala, IVA eta guztira).
  
  CSS Styles:
  
  - stylesheets: @../../estilos/otzara.css
  - styleClass: otzara-container, resumen-panel, boton-exito, boton-secundario
  
  FXML Controller:
  
  @see bezeroLeihoak.otzara.OtzaraKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="bezeroLeihoak.otzara.OtzaraKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/otzara.css"
      styleClass="otzara-container">
      
   <children>
      <Label text="Nire Otzara" styleClass="titulo-principal" />
      
      <HBox spacing="10" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="10" prefWidth="550.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Produktuak" styleClass="titulo-secundario" />
                  <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                     <content>
                        <VBox fx:id="produktuakContainer" spacing="5" />
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            
            <VBox spacing="15" prefWidth="300.0" alignment="TOP_CENTER" styleClass="resumen-panel">
               <children>
                  <Label text="Zure Erosketa" styleClass="resumen-titulo" />
                  <Separator />
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="Totala:" />
                     <Label fx:id="totalaLabel" styleClass="resumen-total" />
                  </HBox>
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="+ 21% IVA:" />
                     <Label fx:id="ivaLabel" />
                  </HBox>
                  <Separator />
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="Ordaintzeko guztira:" style="-fx-font-weight: bold;" />
                     <Label fx:id="guztiraLabel" styleClass="resumen-total" />
                  </HBox>
                  <Separator />
                  <Button onAction="#erosi" text="EROSI" styleClass="boton-exito" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
      </HBox>
   </children>
</VBox>