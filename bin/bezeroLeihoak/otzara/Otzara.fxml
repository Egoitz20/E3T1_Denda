<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="bezeroLeihoak.otzara.OtzaraKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER">
      
   <children>
      <Label text="Nire Otzara">
         <font>
            <Font name="Calibri" size="25.0" />
         </font>
      </Label>
      
      <HBox spacing="10" VBox.vgrow="ALWAYS">
         <children>
            <!-- Panel izquierdo: Lista de productos -->
            <VBox spacing="10" prefWidth="550.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Produktuak">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="produktuakContainer" spacing="5" />
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
            
            <!-- Panel derecho: Resumen de compra -->
            <VBox spacing="15" prefWidth="300.0" alignment="TOP_CENTER" style="-fx-border-color: #ccc; -fx-border-radius: 10; -fx-padding: 15;">
               <children>
                  <Label text="Zure Erosketa" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                  
                  <Separator />
                  
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="Totala:" style="-fx-font-size: 14px;" />
                     <Label fx:id="totalaLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                  </HBox>
                  
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="+ 21% IVA:" style="-fx-font-size: 14px;" />
                     <Label fx:id="ivaLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                  </HBox>
                  
                  <Separator />
                  
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <Label text="Ordaintzeko guztira:" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                     <Label fx:id="guztiraLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
                  </HBox>
                  
                  <Separator />
                  
                  <Button onAction="#erosi" text="EROSI" prefWidth="200.0" style="-fx-font-size: 16px; -fx-background-color: #2ecc71; -fx-text-fill: white;" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <children>
            <Button onAction="#itzuli" text="Itzuli">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>