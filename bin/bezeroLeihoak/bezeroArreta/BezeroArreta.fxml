<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<!--
  ============================================================================
  BEZERO ARRETAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: BezeroArreta.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
  
  Bezeroarentzako arretaren interfaze grafikoa. Bezeroak arazoak edo zalantzak 
  bidaltzeko formularioa. Kontzeptua eta deskribapena idazteko eremuak ditu.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/formularios.css
  - styleClass: formulario-panel, boton-exito, boton-peligro
  
  FXML Controller:
  
  @see bezeroLeihoak.bezeroArreta.BezeroArretaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="bezeroLeihoak.bezeroArreta.BezeroArretaKontrolagailua" 
      spacing="10" 
      alignment="TOP_CENTER" 
      stylesheets="@../../estilos/formularios.css"
      styleClass="formulario-panel"
      xmlns:fx="http://javafx.com/fxml">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Kontzeptua:" styleClass="campo-etiqueta"/>
    <TextArea fx:id="kontzeptua" promptText="Idatzi kontzeptua hemen..." prefRowCount="2" styleClass="campo-texto"/>
    
    <Label text="Arazo deskribapena:" styleClass="campo-etiqueta" />
    <TextArea fx:id="deskribapena" promptText="Idatzi arazoaren deskribapena hemen..." prefRowCount="4" styleClass="campo-texto"/>
    
    <HBox spacing="10" alignment="CENTER">
        <Button onAction="#bidaliSaltzaileeiArazoa" text="Bidali" styleClass="boton-exito"/>
        <Button onAction="#itzuli" text="Itzuli" styleClass="boton-peligro"/>
    </HBox>
</VBox>