<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Kontzeptua:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TextArea promptText="Idatzi kontzeptua hemen..." prefRowCount="2"/>
    
    <Label text="Arazo deskribapena:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
    <TextArea promptText="Idatzi arazoaren deskribapena hemen..." prefRowCount="4"/>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Bidali" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Itzuli" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
    </HBox>
</VBox>