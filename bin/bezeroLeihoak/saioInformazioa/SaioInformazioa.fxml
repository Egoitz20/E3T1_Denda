<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  SAIOAREN INFORMAZIOAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: SaioInformazioa.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
 
  Saioaren informazioaren interfaze grafikoa. Bezeroaren datu pertsonalak 
  ikusteko eta editatzeko leihoa. Bi modu ditu: irakurketa modua eta edizio modua.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/formularios.css
  - styleClass: formulario-panel, boton-editar, boton-exito, boton-secundario
  
  FXML Controller:
 
  @see bezeroLeihoak.saioInformazioa.SaioInformazioaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="bezeroLeihoak.saioInformazioa.SaioInformazioaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="500.0" 
      prefWidth="600.0"
      spacing="15"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/formularios.css"
      styleClass="formulario-panel">
      
   <children>
      <HBox spacing="15" alignment="CENTER">
         <children>
            <Label text="Saioaren Informazioa" styleClass="titulo-principal" />
            <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                <Image url="@../../irudiak/usuario.png" />
            </ImageView>
         </children>
      </HBox>
      
      <Separator prefWidth="400.0" />
      
      <GridPane hgap="15" vgap="12" alignment="CENTER">
         <children>
            <Label text="Izena *:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <TextField fx:id="ipiniIzena" prefWidth="250.0" promptText="Izena" styleClass="campo-texto" />
               <Button fx:id="editatuIzenaButton" text="✏️" prefWidth="40" onAction="#editatuIzena" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Abizena:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <TextField fx:id="ipiniAbizenak" prefWidth="250.0" promptText="Abizenak" styleClass="campo-texto" />
               <Button fx:id="editatuAbizenaButton" text="✏️" prefWidth="40" onAction="#editatuAbizena" styleClass="boton-editar" />
            </HBox>
            
            <Label text="NAN *:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <TextField fx:id="ipiniNan" prefWidth="250.0" promptText="NAN" styleClass="campo-texto" />
               <Button fx:id="editatuNanButton" text="✏️" prefWidth="40" onAction="#editatuNan" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Telefonoa *:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
               <TextField fx:id="ipiniTelefonoa" prefWidth="250.0" promptText="Telefonoa" styleClass="campo-texto" />
               <Button fx:id="editatuTelefonoaButton" text="✏️" prefWidth="40" onAction="#editatuTelefonoa" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Helbidea:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <TextField fx:id="ipiniHelbidea" prefWidth="250.0" promptText="Helbidea" styleClass="campo-texto" />
               <Button fx:id="editatuHelbideaButton" text="✏️" prefWidth="40" onAction="#editatuHelbidea" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Emaila *:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
               <TextField fx:id="ipiniEmaila" prefWidth="250.0" promptText="Emaila" styleClass="campo-texto" />
               <Button fx:id="editatuEmailaButton" text="✏️" prefWidth="40" onAction="#editatuEmaila" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Erabiltzailea *:" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
               <TextField fx:id="ipiniErabiltzailea" prefWidth="250.0" promptText="Erabiltzailea" styleClass="campo-texto" />
               <Button fx:id="editatuErabiltzaileaButton" text="✏️" prefWidth="40" onAction="#editatuErabiltzailea" styleClass="boton-editar" />
            </HBox>
            
            <Label text="Pasahitza *:" GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="campo-etiqueta" />
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="7">
               <TextField fx:id="ipiniPasahitza" prefWidth="250.0" promptText="Pasahitza" styleClass="campo-texto" />
               <Button fx:id="editatuPasahitzaButton" text="✏️" prefWidth="40" onAction="#editatuPasahitza" styleClass="boton-editar" />
            </HBox>
         </children>
         
         <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="80" />
            <ColumnConstraints halignment="LEFT" minWidth="300" />
         </columnConstraints>
      </GridPane>
      
      <Separator prefWidth="400.0" />
      
      <HBox spacing="20" alignment="CENTER">
         <children>
            <Button fx:id="gordeButton" onAction="#gordeInfo" text="Gorde" styleClass="boton-exito" prefWidth="100" />
            <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" prefWidth="100" />
         </children>
      </HBox>
   </children>
</VBox>