<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<!--
  ============================================================================
  RAM PRODUKTUEN TAULAREN INTERFAZE GRAFIKOA
  ============================================================================
  
  File: RamTaula.fxml
  Author: AIA
  Version: 2.0
  Since: 2026
  
  Description:
  
  RAM produktuen taularen interfaze grafikoa. Taula honek RAM kategorian dauden 
  produktu guztiak erakusten ditu: izena, deskribapena, salneurria eta kantitatea.
  
  CSS Styles:
  
  - stylesheets: @../../estilos/tienda.css
  - styleClass: tienda-container, tabla-productos, pagination
  
  FXML Controller:
  
  @see bezeroLeihoak.ramTaula.RamTaulaKontrolagailua
  
  ============================================================================
-->

<VBox fx:controller="bezeroLeihoak.ramTaula.RamTaulaKontrolagailua" 
      xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="550.0" 
      prefWidth="900.0"
      spacing="10"
      alignment="TOP_CENTER"
      stylesheets="@../../estilos/tienda.css"
      styleClass="tienda-container">
      
   <children>
      <Label text="RAM Memory" styleClass="titulo-principal" />
      
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS" prefHeight="400.0" styleClass="tabla-productos">
        <columns>
          <TableColumn fx:id="izenaColumn" prefWidth="250.0" text="Izena" />
          <TableColumn fx:id="deskribapenaColumn" prefWidth="300.0" text="Deskribapena" />
          <TableColumn fx:id="salneurriaColumn" prefWidth="120.0" text="Salneurria (€)" />
          <TableColumn fx:id="kantitateaColumn" prefWidth="180.0" text="Kantitatea" />
        </columns>
      </TableView>
      
      <HBox spacing="10" alignment="CENTER">
         <Pagination fx:id="pagination" styleClass="pagination" />
      </HBox>
      
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button onAction="#gehituOtzara" text="Gehitu Otzara" styleClass="boton-primario" />
         <Button onAction="#itzuli" text="Itzuli" styleClass="boton-secundario" />
      </HBox>
   </children>
</VBox>